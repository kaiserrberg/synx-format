{
  "name": "synx-vscode",
  "displayName": "SYNX \u2014 Active Data Format",
  "description": "Syntax highlighting, IntelliSense, diagnostics, navigation, formatting, and tools for .synx files. By APERTURESyndicate.",
  "version": "3.6.0",
  "publisher": "APERTURESyndicate",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "synx",
    "config",
    "data format",
    "json alternative",
    "yaml alternative",
    "active data",
    "configuration"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "synx",
        "aliases": ["SYNX", "synx"],
        "extensions": [".synx"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/synx-file.svg",
          "dark": "./icons/synx-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "synx",
        "scopeName": "source.synx",
        "path": "./syntaxes/synx.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "synx.convertToJson",
        "title": "SYNX: Convert to JSON"
      },
      {
        "command": "synx.convertFromJson",
        "title": "SYNX: Convert JSON \u2192 SYNX"
      },
      {
        "command": "synx.freeze",
        "title": "SYNX: Freeze (resolve all markers)"
      },
      {
        "command": "synx.preview",
        "title": "SYNX: Preview parsed output"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .synx",
          "command": "synx.convertToJson",
          "group": "synx@1"
        },
        {
          "when": "resourceExtname == .synx",
          "command": "synx.freeze",
          "group": "synx@2"
        },
        {
          "when": "resourceExtname == .json",
          "command": "synx.convertFromJson",
          "group": "synx@3"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .synx",
          "command": "synx.convertToJson",
          "group": "synx@1"
        },
        {
          "when": "resourceExtname == .synx",
          "command": "synx.freeze",
          "group": "synx@2"
        },
        {
          "when": "resourceExtname == .synx",
          "command": "synx.preview",
          "group": "synx@3"
        },
        {
          "when": "resourceExtname == .json",
          "command": "synx.convertFromJson",
          "group": "synx@4"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/APERTURESyndicate/synx-format"
  },
  "license": "MIT"
}
