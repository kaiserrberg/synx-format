{
  "comments": {
    "lineComment": "#",
    "blockComment": ["//", ""]
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\S+.*$",
    "decreaseIndentPattern": "^\\s*$"
  },
  "folding": {
    "offSide": true
  }
}
